{
  "name": "@youssef-amarzou/indus",
  "version": "1.0.0",
  "description": "INDUS — Plateforme Industrielle Intégrée",
  "main": "electron/main.js",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "release": "npm run build && electron-builder --publish always"
  },
  "build": {
    "appId": "com.indus.platform",
    "productName": "INDUS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "screenshots/app-icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "screenshots/app-icon.ico",
      "license": "MIT"
    },
    "publish": {
      "provider": "github",
      "owner": "Youssef-AMARZOU",
      "repo": "scada-hmi"
    }
  },
  "devDependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "cross-env": "^7.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0",
    "jsmodbus": "^4.0.10",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@influxdata/influxdb-client": "^1.35.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "i18next": "^26.3.1",
    "lucide-react": "^1.17.0",
    "mqtt": "^5.15.1",
    "node-opcua": "^2.173.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.17.0",
    "three": "^0.184.0",
    "zustand": "^5.0.14"
  }
}
